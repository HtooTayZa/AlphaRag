# ==============================================================================
# AlphaRAG: General Document Assistant — Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to exactly `.env`
# 2. Fill in your actual API keys below.
# 3. NEVER commit your actual `.env` file to version control.

# --- LLM Provider (Groq) ---
# Required for metadata extraction and RAG generation.
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# --- Networking & Downloads ---
# Optional: Bypasses network throttling/blocks for HuggingFace model downloads
HF_ENDPOINT="https://hf-mirror.com"

# Optional: Add your HuggingFace token if using gated/private embedding models
# HUGGINGFACE_HUB_TOKEN="your_hf_token_here"

# --- Cloud Database (Qdrant) ---
# For local embedded mode (default), leave these blank/commented.
# Fill these in ONLY if you are deploying to production via Qdrant Cloud.
# QDRANT_URL="https://your-cluster-id.cloud.qdrant.io"
# QDRANT_API_KEY="your_qdrant_cloud_api_key_here"

# --- Application Settings (Optional Overrides) ---
# These have sensible defaults in src/config.py, but can be overridden here.
# COLLECTION_NAME="alpharag_general_docs"
# PARENT_CHUNK_SIZE="1500"
# CHILD_CHUNK_SIZE="200"