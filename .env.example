# ==============================================================================
# AlphaRAG: Institutional Knowledge Extractor — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.

# --- LLM Provider (Groq) ---
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY="groq_api_key"

# --- Qdrant Configuration ---
# For local mode (default), these are not needed.
# Uncomment and fill in ONLY if you are using Qdrant Cloud.
# QDRANT_URL="https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io"
# QDRANT_API_KEY="your_qdrant_cloud_api_key_here"

# --- Application Settings (Optional Overrides) ---
# These have defaults in src/config.py; override here if needed.
# COLLECTION_NAME="alpharag_financial_docs"
# PARENT_CHUNK_SIZE="1500"
# CHILD_CHUNK_SIZE="200"
